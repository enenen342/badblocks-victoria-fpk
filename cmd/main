#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)"
APP_DIR="$ROOT_DIR/target"
BIN="$APP_DIR/bin/fn-badblocks-victoria"
UI_DIR="$APP_DIR/ui/web"
VAR_DIR="${TRIM_PKGVAR:-$ROOT_DIR/var}"
PID_FILE="$VAR_DIR/server.pid"
LOG_FILE="$VAR_DIR/server.log"
DEBUG_LOG="/tmp/badblocks-victoria.log"
ADDR="${ADDR:-0.0.0.0:24046}"
export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:${PATH:-}"

log_msg() {
  mkdir -p "$VAR_DIR" 2>/dev/null || true
  msg="$(date '+%Y-%m-%d %H:%M:%S') $*"
  echo "$msg" >>"$LOG_FILE" 2>/dev/null || true
  echo "$msg" >>"$DEBUG_LOG" 2>/dev/null || true
}

fix_binary_privilege() {
  if [ -f "$BIN" ]; then
    chown root:root "$BIN" 2>/dev/null || true
    chmod 4755 "$BIN" 2>/dev/null || true
  fi
}

is_running() {
  [ -f "$PID_FILE" ] || return 1
  pid="$(cat "$PID_FILE" 2>/dev/null || true)"
  [ -n "$pid" ] || return 1
  kill -0 "$pid" 2>/dev/null
}

start() {
  mkdir -p "$VAR_DIR"
  if is_running; then
    echo "already running"
    return 0
  fi

  fix_binary_privilege
  log_msg "start root=$ROOT_DIR app=$APP_DIR bin=$BIN ui=$UI_DIR addr=$ADDR trim_pkgvar=${TRIM_PKGVAR:-}"

  if [ ! -x "$BIN" ]; then
    log_msg "binary not executable or missing"
    return 1
  fi

  nohup "$BIN" -addr "$ADDR" -ui "$UI_DIR" >>"$LOG_FILE" 2>&1 &
  echo $! >"$PID_FILE"
  sleep 2

  if command -v ss >/dev/null 2>&1; then
    ss -lntp | grep 24046 >>"$DEBUG_LOG" 2>&1 || log_msg "port 24046 not listening"
  fi

  echo "started"
}

stop() {
  if is_running; then
    pid="$(cat "$PID_FILE")"
    kill "$pid" 2>/dev/null || true
    sleep 1
    kill -9 "$pid" 2>/dev/null || true
  fi
  rm -f "$PID_FILE"
  echo "stopped"
}

status() {
  if is_running; then
    echo "running"
    exit 0
  fi
  echo "stopped"
  exit 3
}

case "${1:-status}" in
  start) start ;;
  stop) stop ;;
  restart) stop; start ;;
  status) status ;;
  *) exit 1 ;;
esac
